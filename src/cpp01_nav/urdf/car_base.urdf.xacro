<!-- 底盘实现 -->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- 包含计算 惯性矩阵 的 xacro -->
    <xacro:include filename="common_inertial.xacro"/>

    <!-- 声明变量 -->
    <xacro:property name = "PI" value = "3.1415927"/>
    <xacro:property name = "car_length" value = "1.5"/>
    <xacro:property name = "car_width" value = "1.2"/>
    <xacro:property name = "car_height" value = "0.5"/>
    <xacro:property name = "car_base_weight" value = "30.0"/>
    <xacro:property name = "wheel_radius" value = "0.2"/>
    <xacro:property name = "wheel_width" value = "0.1"/>
    <xacro:property name = "wheel_weight" value = "20.0"/>
    <xacro:property name = "car_to_floor_distance" value = "0.15"/>
    <!-- 轮胎距离底盘的偏移量 -->
    <xacro:property name = "wheel_joint_x" value = "${car_length / 4}"/>
    <xacro:property name = "wheel_joint_y" value = "${car_width / 2}"/>
    <xacro:property name = "wheel_joint_z" value = "${-(car_to_floor_distance + car_height / 2 - wheel_radius)}"/>
    <!-- 颜色设为全局变量 -->
    <material name="yellow">
        <color rgba="0.9 0.6 0.2 1.0"/>
    </material>
    <material name="black">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>


    <!-- 设置 base_footprint -->
     <link name="base_footprint">
        <visual>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
        </visual>
    </link>
    <!-- 设置 base_link -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${car_length} ${car_width} ${car_height}"/>
            </geometry>
            <material name="yellow"/>
        </visual>
        <collision>
            <geometry>
                <box size="${car_length + 0.01} ${car_width + 0.01} ${car_height + 0.01}"/>
            </geometry>
        </collision>          
        <!-- 添加质量和惯性 -->
        <xacro:box_inertia m = "${car_base_weight}" l = "${car_length}" w = "${car_width}" h = "${car_height}"
                           xyz = "0 0 0" rpy = "0 0 0" />
    </link>

    <!-- 使用 joint 关联 1和2 -->
    <joint name="base_link_to_base_footprint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <!-- 底盘偏移量，离地距离 -->
        <origin xyz="0.0 0.0 ${car_to_floor_distance + (car_height + 0.001)/2}"/>
    </joint>

    <!-- 设置 gazebo 标签 -->
    <gazebo reference = "base_link">
        <material>Gazebo/Yellow</material>
        <gravity>true</gravity>
    </gazebo>


    <!-- 定义车轮相关的宏 -->
    <!-- 宏（函数）创建规则：封装可被复用的代码，要变的数据以参数的方式传入 -->
    <xacro:macro name = "wheel_and_joint" params = "link_name left_flag front_flag">
        <!-- 添加一个车轮 -->
        <link name="${link_name}">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="black"/>
                <!-- 车轮翻滚90度 -->
                <origin rpy="${PI / 2} 0.0 0.0"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius + 0.01}" length="${wheel_width + 0.01}"/>
                </geometry>
                <!-- 车轮翻滚90度 -->
                <origin rpy="${PI / 2} 0.0 0.0"/>
            </collision>
            <!-- 添加质量和惯性 -->
            <xacro:cylinder_inertia m = "${wheel_weight}" r = "${wheel_radius}" h = "${wheel_width}"
                                    xyz = "0 0 0" rpy = "${PI / 2} 0.0 0.0" />
        </link>

        <!-- 将车轮与 base_link 关联 -->
        <joint name="${link_name}_to_base_link" type="continuous">
            <parent link="base_link"/>
            <child link="${link_name}"/>
            <!-- 车轮相对于底盘的位置 -->
            <origin xyz="${wheel_joint_x * front_flag} ${wheel_joint_y * left_flag} ${wheel_joint_z}"/>
            <!-- 车轮旋转 -->
            <axis xyz="0 1 0"/>
        </joint>

        <!-- 设置 gazebo 标签 -->
        <gazebo reference = "${link_name}">
            <material>Gazebo/Grey</material>
            <!-- 摩擦系数，值越小阻力越小 -->
            <mu1 value = "20.0"/>
            <mu2 value = "20.0"/>
            <kp value="1000000000.0" />
            <kd value="1.0" />

            <!-- 增大地面摩擦力，避免打滑 -->
            <friction>5.0</friction>
            <!-- 降低滚动摩擦 -->
            <rolling_friction>0.01</rolling_friction>
            <!-- 适度阻尼，避免车轮抖动 -->
            <damping>0.5</damping>
        </gazebo>
    </xacro:macro>


    <!-- 调用宏，生成多个车轮，并与 base_link 关联 -->
    <xacro:wheel_and_joint link_name = "left_back" left_flag = "1" front_flag = "-1"/>
    <xacro:wheel_and_joint link_name = "left_front" left_flag = "1" front_flag = "1"/>
    <xacro:wheel_and_joint link_name = "right_back" left_flag = "-1" front_flag = "-1"/>
    <xacro:wheel_and_joint link_name = "right_front" left_flag = "-1" front_flag = "1"/>
</robot>